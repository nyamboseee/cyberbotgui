<Window x:Class="CyberBotWPF.TaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot — Task Assistant"
        Height="620" Width="720"
        MinHeight="550" MinWidth="620"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E1A"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <!-- Primary button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#00FF9F"/>
            <Setter Property="Foreground" Value="#0A0E1A"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00FFB8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00CC80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#1E3A5F"/>
                                <Setter Property="Foreground" Value="#5A6A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger button -->
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF4060"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#FF4060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A0010"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Success button -->
        <Style x:Key="SuccessBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#00FF9F"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#00FF9F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#002A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input style -->
        <Style x:Key="TaskInput" TargetType="TextBox">
            <Setter Property="Background" Value="#141C2E"/>
            <Setter Property="Foreground" Value="#E8F0FF"/>
            <Setter Property="CaretBrush" Value="#00FF9F"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1E3A5F"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#00FF9F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Add task form -->
            <RowDefinition Height="*"/>
            <!-- Task list -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="TASK ASSISTANT"
                           FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                           Foreground="#00FF9F"/>
                <TextBlock Text="Manage your cybersecurity tasks and reminders"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="#5A6A8A" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" Background="#141C2E" CornerRadius="8" Padding="16,8">
                <StackPanel>
                    <TextBlock Text="TASKS" FontFamily="Consolas" FontSize="10"
                               Foreground="#5A6A8A" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TaskCountLabel" Text="0"
                               FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                               Foreground="#00FF9F" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Add task form -->
        <Border Grid.Row="1" Background="#0F1626" CornerRadius="10"
                BorderBrush="#1E3A5F" BorderThickness="1"
                Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="// ADD NEW TASK" FontFamily="Consolas" FontSize="10"
                           Foreground="#5A6A8A" FontWeight="Bold" Margin="0,0,0,12"/>

                <!-- Title -->
                <TextBlock Text="Task Title" FontFamily="Consolas" FontSize="11"
                           Foreground="#5A6A8A" Margin="0,0,0,4"/>
                <TextBox x:Name="TaskTitleInput" Style="{StaticResource TaskInput}"
                         Margin="0,0,0,10"/>

                <!-- Description -->
                <TextBlock Text="Description" FontFamily="Consolas" FontSize="11"
                           Foreground="#5A6A8A" Margin="0,0,0,4"/>
                <TextBox x:Name="TaskDescInput" Style="{StaticResource TaskInput}"
                         Margin="0,0,0,10"/>

                <!-- Reminder row -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Reminder (optional)" FontFamily="Consolas" FontSize="11"
                                   Foreground="#5A6A8A" Margin="0,0,0,4"/>
                        <TextBox x:Name="TaskReminderInput" Style="{StaticResource TaskInput}"
                                 FontSize="12"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Timeframe" FontFamily="Consolas" FontSize="11"
                                   Foreground="#5A6A8A" Margin="0,0,0,4"/>
                        <ComboBox x:Name="ReminderTimeframe"
                              Background="#141C2E" Foreground="#E8F0FF"
                               FontFamily="Consolas" FontSize="12"
                               BorderBrush="#1E3A5F" Height="38">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#141C2E"/>
                                    <Setter Property="Foreground" Value="#E8F0FF"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBoxItem Content="No reminder" IsSelected="True"/>
                            <ComboBoxItem Content="Tomorrow"/>
                            <ComboBoxItem Content="In 3 days"/>
                            <ComboBoxItem Content="In 1 week"/>
                            <ComboBoxItem Content="In 2 weeks"/>
                            <ComboBoxItem Content="In 1 month"/>
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="4" Content="ADD TASK"
                            Style="{StaticResource PrimaryBtn}"
                            VerticalAlignment="Bottom"
                            Click="AddTask_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Task list -->
        <Border Grid.Row="2" Background="#0F1626" CornerRadius="10"
                BorderBrush="#1E3A5F" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- List header -->
                <Border Grid.Row="0" BorderBrush="#1E3A5F" BorderThickness="0,0,0,1" Padding="16,10">
                    <TextBlock Text="// YOUR TASKS" FontFamily="Consolas" FontSize="10"
                               Foreground="#5A6A8A" FontWeight="Bold"/>
                </Border>

                <!-- Scrollable task items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,4">
                    <StackPanel x:Name="TaskListPanel" Margin="0,4,0,4"/>
                </ScrollViewer>

                <!-- Empty state -->
                <TextBlock x:Name="EmptyLabel" Grid.Row="1"
                           Text="No tasks yet. Add your first cybersecurity task above."
                           FontFamily="Consolas" FontSize="12"
                           Foreground="#5A6A8A"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Margin="0,12,0,0">
            <TextBlock x:Name="StatusLabel"
                       Text="Ready. Add a task to get started."
                       FontFamily="Consolas" FontSize="11"
                       Foreground="#5A6A8A"/>
        </Border>
    </Grid>
</Window>
