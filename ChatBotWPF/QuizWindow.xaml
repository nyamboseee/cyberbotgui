 <Window x:Class="CyberBotWPF.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot — Cybersecurity Quiz"
        Height="600" Width="700"
        MinHeight="550" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E1A"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDeep"      Color="#0A0E1A"/>
        <SolidColorBrush x:Key="BgPanel"     Color="#0F1626"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#00FF9F"/>
        <SolidColorBrush x:Key="AccentBlue"  Color="#00B4FF"/>
        <SolidColorBrush x:Key="AccentRed"   Color="#FF4060"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8F0FF"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#5A6A8A"/>
        <SolidColorBrush x:Key="BorderGlow"  Color="#1E3A5F"/>

        <!-- Answer button style -->
        <Style x:Key="AnswerBtn" TargetType="Button">
            <Setter Property="Background" Value="#141C2E"/>
            <Setter Property="Foreground" Value="#E8F0FF"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#1E3A5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2540"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00B4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F1E35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Next/Restart button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#00FF9F"/>
            <Setter Property="Foreground" Value="#0A0E1A"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="24,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00FFB8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00CC80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#1E3A5F"/>
                                <Setter Property="Foreground" Value="#5A6A8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Progress -->
            <RowDefinition Height="*"/>
            <!-- Question area -->
            <RowDefinition Height="Auto"/>
            <!-- Feedback -->
            <RowDefinition Height="Auto"/>
            <!-- Controls -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="CYBERSECURITY QUIZ"
                           FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                           Foreground="#00FF9F"/>
                <TextBlock Text="Test your knowledge on cybersecurity topics"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="#5A6A8A" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" Background="#141C2E" CornerRadius="8"
                    Padding="16,8">
                <StackPanel>
                    <TextBlock Text="SCORE" FontFamily="Consolas" FontSize="10"
                               Foreground="#5A6A8A" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ScoreLabel" Text="0 / 0"
                               FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                               Foreground="#00FF9F" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Progress bar -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="ProgressLabel"
                       Text="Question 1 of 12"
                       FontFamily="Consolas" FontSize="11"
                       Foreground="#5A6A8A" Margin="0,0,0,6"/>
            <Border Grid.Row="1" Background="#141C2E" CornerRadius="4">
                <Border x:Name="ProgressBar" Background="#00B4FF"
                        CornerRadius="4" HorizontalAlignment="Left"
                        Height="8" Width="0"/>
            </Border>
        </Grid>

        <!-- Question + answers -->
        <StackPanel Grid.Row="2">
            <!-- Question type badge -->
            <Border Background="#1A2540" CornerRadius="4"
                    Padding="10,4" HorizontalAlignment="Left" Margin="0,0,0,12">
                <TextBlock x:Name="QuestionTypeBadge" Text="MULTIPLE CHOICE"
                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                           Foreground="#00B4FF"/>
            </Border>

            <!-- Question text -->
            <TextBlock x:Name="QuestionText"
                       Text="Question goes here"
                       FontFamily="Consolas" FontSize="15"
                       Foreground="#E8F0FF"
                       TextWrapping="Wrap"
                       LineHeight="26"
                       Margin="0,0,0,16"/>

            <!-- Answer buttons -->
            <Button x:Name="BtnA" Style="{StaticResource AnswerBtn}" Click="Answer_Click" Tag="0"/>
            <Button x:Name="BtnB" Style="{StaticResource AnswerBtn}" Click="Answer_Click" Tag="1"/>
            <Button x:Name="BtnC" Style="{StaticResource AnswerBtn}" Click="Answer_Click" Tag="2"/>
            <Button x:Name="BtnD" Style="{StaticResource AnswerBtn}" Click="Answer_Click" Tag="3"/>
        </StackPanel>

        <!-- Feedback panel -->
        <Border Grid.Row="3" x:Name="FeedbackPanel"
                Background="#141C2E" CornerRadius="8"
                Padding="16,12" Margin="0,16,0,0"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="FeedbackResult"
                           FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                           Foreground="#00FF9F"/>
                <TextBlock x:Name="FeedbackExplanation"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="#E8F0FF" TextWrapping="Wrap"
                           Margin="0,6,0,0" LineHeight="20"/>
            </StackPanel>
        </Border>

        <!-- Controls -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="FinalMessage" Grid.Column="0"
                       FontFamily="Consolas" FontSize="12"
                       Foreground="#5A6A8A" VerticalAlignment="Center"
                       TextWrapping="Wrap"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="RestartBtn" Content="RESTART"
                        Style="{StaticResource PrimaryBtn}"
                        Width="110" Margin="0,0,10,0"
                        Visibility="Collapsed"
                        Click="Restart_Click"/>
                <Button x:Name="NextBtn" Content="NEXT"
                        Style="{StaticResource PrimaryBtn}"
                        Width="110" IsEnabled="False"
                        Click="Next_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
