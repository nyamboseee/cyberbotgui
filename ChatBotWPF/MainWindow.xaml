<Window x:Class="CyberBotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot — Cybersecurity Awareness Assistant"
        Height="700" Width="950"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#0A0E1A"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Colours -->
        <SolidColorBrush x:Key="BgDeep"       Color="#0A0E1A"/>
        <SolidColorBrush x:Key="BgPanel"      Color="#0F1626"/>
        <SolidColorBrush x:Key="BgInput"      Color="#141C2E"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#00FF9F"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#00B4FF"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#FF4060"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E8F0FF"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#5A6A8A"/>
        <SolidColorBrush x:Key="BorderGlow"   Color="#1E3A5F"/>

        <!-- Scrollbar style -->
        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#1E3A5F" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="6"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1"
                                       Style="{StaticResource SlimScrollBar}"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Send button style -->
        <Style x:Key="SendBtn" TargetType="Button">
            <Setter Property="Background" Value="#00FF9F"/>
            <Setter Property="Foreground" Value="#0A0E1A"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="18,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00FFB8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00CC80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Clear button style -->
        <Style x:Key="ClearBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5A6A8A"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1E3A5F"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2540"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00B4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="ChatInput" TargetType="TextBox">
            <Setter Property="Background" Value="#141C2E"/>
            <Setter Property="Foreground" Value="#E8F0FF"/>
            <Setter Property="CaretBrush" Value="#00FF9F"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1E3A5F"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#00FF9F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Body -->
            <RowDefinition Height="Auto"/>
            <!-- Sentiment bar -->
            <RowDefinition Height="70"/>
            <!-- Input bar -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <!-- Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Chat area -->
        </Grid.ColumnDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="#0F1626"
                BorderBrush="#1E3A5F" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬡" FontSize="28" Foreground="#00FF9F"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CYBER" FontFamily="Consolas" FontSize="18"
                                   FontWeight="Bold" Foreground="#00FF9F" LineHeight="18"/>
                        <TextBlock Text="BOT" FontFamily="Consolas" FontSize="18"
                                   FontWeight="Bold" Foreground="#00B4FF" LineHeight="18"/>
                    </StackPanel>
                    <TextBlock Text="v2.0" FontFamily="Consolas" FontSize="10"
                               Foreground="#5A6A8A" VerticalAlignment="Bottom" Margin="6,0,0,4"/>
                </StackPanel>

                <!-- Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#00FF9F" Margin="0,0,6,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00FF9F" BlurRadius="8" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="StatusText"
                               Text="ONLINE — Ready to assist"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="#5A6A8A"/>
                </StackPanel>

                <!-- User info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="UserLabel"
                               Text="Guest"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="#E8F0FF" VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <Border Background="#1A2540" CornerRadius="16"
                            Width="32" Height="32">
                        <TextBlock x:Name="UserAvatar" Text="?"
                                   FontFamily="Consolas" FontWeight="Bold"
                                   FontSize="14" Foreground="#00FF9F"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="0"
                Background="#0F1626"
                BorderBrush="#1E3A5F" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,10">
                <StackPanel Margin="0,0,0,20">

                    <!-- Memory section -->
                    <TextBlock Text="// MEMORY" FontFamily="Consolas" FontSize="10"
                               Foreground="#5A6A8A" Margin="16,10,16,8" FontWeight="Bold"/>
                    <Border Background="#141C2E" CornerRadius="8"
                            Margin="10,0,10,16" Padding="12">
                        <StackPanel>
                            <TextBlock x:Name="MemoryName" Text="Name: —"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="#00FF9F"/>
                            <TextBlock x:Name="MemoryTopic" Text="Interest: —"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="#00B4FF" Margin="0,4,0,0"/>
                            <TextBlock x:Name="MemoryCount" Text="Messages: 0"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="#5A6A8A" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Sentiment section -->
                    <TextBlock Text="// SENTIMENT" FontFamily="Consolas" FontSize="10"
                               Foreground="#5A6A8A" Margin="16,0,16,8" FontWeight="Bold"/>
                    <Border Background="#141C2E" CornerRadius="8"
                            Margin="10,0,10,16" Padding="12">
                        <StackPanel>
                            <TextBlock x:Name="SentimentLabel" Text="Neutral"
                                       FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="#E8F0FF"/>
                            <TextBlock x:Name="SentimentEmoji" Text="😐"
                                       FontSize="22" Margin="0,4,0,0"/>
                            <TextBlock x:Name="SentimentDesc"
                                       Text="User mood appears neutral."
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="#5A6A8A" TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Quick topics -->
                    <TextBlock Text="// QUICK TOPICS" FontFamily="Consolas" FontSize="10"
                               Foreground="#5A6A8A" Margin="16,0,16,8" FontWeight="Bold"/>

                    <Button Content="🔐  Passwords" Style="{StaticResource ClearBtn}"
                            Height="34" Margin="10,2,10,2"
                            Click="QuickTopic_Click" Tag="password safety"/>
                    <Button Content="🎣  Phishing" Style="{StaticResource ClearBtn}"
                            Height="34" Margin="10,2,10,2"
                            Click="QuickTopic_Click" Tag="phishing tips"/>
                    <Button Content="🦠  Malware" Style="{StaticResource ClearBtn}"
                            Height="34" Margin="10,2,10,2"
                            Click="QuickTopic_Click" Tag="malware protection"/>
                    <Button Content="🔒  Privacy" Style="{StaticResource ClearBtn}"
                            Height="34" Margin="10,2,10,2"
                            Click="QuickTopic_Click" Tag="privacy tips"/>
                    <Button Content="🛡️  2FA" Style="{StaticResource ClearBtn}"
                            Height="34" Margin="10,2,10,2"
                            Click="QuickTopic_Click" Tag="two factor authentication"/>
                    <Button Content="🌐  VPN" Style="{StaticResource ClearBtn}"
                            Height="34" Margin="10,2,10,2"
                            Click="QuickTopic_Click" Tag="VPN benefits"/>
                    <Button Content="  Scams" Style="{StaticResource ClearBtn}"
                            Height="34" Margin="10,2,10,2"
                            Click="QuickTopic_Click" Tag="online scams"/>

                    <!-- Divider -->
                    <Border Background="#1E3A5F" Height="1" Margin="10,12,10,12"/>

                    <!-- Tools section -->
                    <TextBlock Text="// TOOLS" FontFamily="Consolas" FontSize="10"
                               Foreground="#5A6A8A" Margin="16,0,16,8" FontWeight="Bold"/>

                    <Button Content="Task Manager" Style="{StaticResource ClearBtn}"
                            Height="34" Margin="10,2,10,2"
                            Click="OpenTaskManager_Click"/>

                    <Button Content="Start Quiz" Style="{StaticResource ClearBtn}"
                            Height="34" Margin="10,2,10,2"
                            Click="OpenQuiz_Click"/>

                    <Button Content="Activity Log" Style="{StaticResource ClearBtn}"
                            Height="34" Margin="10,2,10,2"
                            Click="ShowActivityLog_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══ CHAT AREA ═══ -->
        <Border Grid.Row="1" Grid.Column="1" Background="#0A0E1A">
            <ScrollViewer x:Name="ChatScroller"
                          Style="{StaticResource SlimScrollViewer}"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,16">
                <StackPanel x:Name="ChatPanel" Margin="0,0,10,0"/>
            </ScrollViewer>
        </Border>

        <!-- ═══ SENTIMENT INDICATOR BAR ═══ -->
        <Border Grid.Row="2" Grid.Column="1"
                Background="#0F1626"
                BorderBrush="#1E3A5F" BorderThickness="0,1,0,0"
                Padding="20,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="MOOD DETECT:"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="#5A6A8A" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <Border Grid.Column="1" Background="#141C2E" CornerRadius="4" Height="6">
                    <Border x:Name="SentimentBar" Background="#00FF9F"
                            CornerRadius="4" HorizontalAlignment="Left"
                            Width="200"/>
                </Border>
                <TextBlock Grid.Column="2" x:Name="SentimentBarLabel"
                           Text="NEUTRAL" FontFamily="Consolas" FontSize="10"
                           Foreground="#5A6A8A" VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- ═══ INPUT BAR ═══ -->
        <Border Grid.Row="3" Grid.Column="1"
                Background="#0F1626"
                BorderBrush="#1E3A5F" BorderThickness="0,1,0,0">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         x:Name="InputBox"
                         Style="{StaticResource ChatInput}"
                         Height="44"
                         KeyDown="InputBox_KeyDown"
                         TextChanged="InputBox_TextChanged"/>

                <Button Grid.Column="2"
                        Content="SEND"
                        Style="{StaticResource SendBtn}"
                        Height="44"
                        Click="SendButton_Click"/>

                <Button Grid.Column="4"
                        Content="CLEAR"
                        Style="{StaticResource ClearBtn}"
                        Height="44"
                        Click="ClearButton_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
